# ==============================================================
# Hello Module - Environment Configuration
# ==============================================================
# Copy this file to .env and customize for your deployment.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#
# Documentation: hello-module/README.md
# ==============================================================

# ==============================================================
# Required: Domain
# ==============================================================
# The domain where your Docker Lab instance is running.
# The hello module will be accessible at hello-module.${DOMAIN}

# CUSTOMIZE: Set to your actual domain
DOMAIN=example.com

# ==============================================================
# Module Settings
# ==============================================================

# CUSTOMIZE: The greeting message displayed on the page
HELLO_MODULE_GREETING=Hello from PeerMesh!

# CUSTOMIZE: The subdomain prefix for this module
# The module will be accessible at ${HELLO_MODULE_SUBDOMAIN}.${DOMAIN}
HELLO_MODULE_SUBDOMAIN=hello-module
